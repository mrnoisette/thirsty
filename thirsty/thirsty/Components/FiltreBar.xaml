<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="thirsty.Components.FiltreBar">

    <Grid x:Name="FiltrePannel"
          BackgroundColor="White"
          Padding="20">
        <VerticalStackLayout Spacing="15">
            <BoxView HeightRequest="4" WidthRequest="40"
                     Color="Gray" HorizontalOptions="Center"
                     CornerRadius="2"/>
            <Label Text="Filtres" FontSize="20" FontAttributes="Bold"/>
            
            <Slider Minimum="0" Maximum="100" Value="50"/>

            <Button Text="Appliquer" Clicked="Appliquer_Clicked"/>
        </VerticalStackLayout>
    </Grid>
    
</toolkit:Popup>