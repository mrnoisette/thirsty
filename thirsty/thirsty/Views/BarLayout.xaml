<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:components="clr-namespace:thirsty.Components"
             xmlns:views="clr-namespace:thirsty.Views"
             x:Class="thirsty.Views.BarLayout">

    <Grid>
        
        <!-- Carte -->
        <views:Carte x:Name="carte"/>
        
        <!-- ListeBar -->
        <views:ListeBar x:Name="listeBar"/>

        <!-- Searchbar -->
        <components:Searchbar x:Name="searchbar" Margin="10,10,10,0" VerticalOptions="Start"/> 

    </Grid>

</ContentView>
